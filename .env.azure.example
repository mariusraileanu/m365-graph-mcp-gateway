# Azure deployment environment
# Copy to .env.azure.prod (or .env.azure.dev) and fill in your values.
# These files are gitignored — only this example is tracked.
#
# AZURE_ENV_LABEL drives default naming for all resources.
# All other variables override defaults in scripts/azure.sh.
# Only set what you need to change.

AZURE_ENV_LABEL=dev

AZURE_RESOURCE_GROUP=rg-graph-mcp-dev
AZURE_CONTAINERAPPS_ENV=cae-graph-mcp-dev
AZURE_ACR_NAME=graphmcpdevacr
AZURE_KEY_VAULT_NAME=kvgraphmcpdev
AZURE_LOCATION=eastus
AZURE_LAW_NAME=law-graph-mcp-dev
AZURE_STORAGE_ACCOUNT=graphmcpdevst
AZURE_NFS_STORAGE_NAME=graph-mcp-nfs-dev
AZURE_VNET_NAME=vnet-graph-mcp-dev
AZURE_SUBNET_NAME=snet-containerapps-dev
