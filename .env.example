# Required: Azure AD App Registration
GRAPH_MCP_CLIENT_ID=
GRAPH_MCP_TENANT_ID=

# Optional: Server configuration
# PORT=3000
# HOST=0.0.0.0
# PUBLIC_HOST=http://localhost:3000
# NODE_ENV=production
# LOG_LEVEL=debug

# Optional: Encrypt persisted MSAL token cache (AES-256-GCM)
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# When unset, token cache is stored in plaintext (a warning is logged on startup).
# GRAPH_TOKEN_CACHE_ENCRYPTION_KEY=