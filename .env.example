# Required: Azure AD App Registration
GRAPH_MCP_CLIENT_ID=
GRAPH_MCP_TENANT_ID=

# Required: Identity binding (every deployment must know who it belongs to)
# USER_SLUG controls cache path isolation and appears in logs/audit.
# Use lowercase alphanumeric + hyphens, 2-31 chars, starting with a letter.
USER_SLUG=dev-local
# EXPECTED_AAD_OBJECT_ID is the Entra object ID (UUID) this instance is pinned to.
# Find it: az ad signed-in-user show --query id -o tsv
EXPECTED_AAD_OBJECT_ID=

# Optional: Server configuration
# PORT=3000
# HOST=0.0.0.0
# PUBLIC_HOST=http://localhost:3000
# NODE_ENV=production
# LOG_LEVEL=debug

# Optional: Encrypt persisted MSAL token cache (AES-256-GCM)
# Generate a key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# When unset, token cache is stored in plaintext (a warning is logged on startup).
# GRAPH_TOKEN_CACHE_ENCRYPTION_KEY=